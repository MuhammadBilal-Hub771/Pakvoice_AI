APP_NAME=PakVoice API
VERSION=1.0.0
DEBUG=True

# Generate a secret key for JWT tokens
SECRET_KEY=dev-secret-key-change-in-production-abc123xyz

# AI - OpenAI (replace with your actual key)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# RAG
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=contentpk_kb
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=3

# Files
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=.txt,.md,.pdf,.docx

# Rate Limiting
RATE_LIMIT=30/minute

# Google OAuth (leave empty for dev mode — auto-login as test user)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Image Generation (GPT Image 2)
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=high
IMAGE_STORAGE_DIR=./generated_images

# CORS
ALLOWED_ORIGINS=http://localhost:3000
